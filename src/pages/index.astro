---
import '../styles/global.css';
import Header from '../components/Header.astro';
import { Image } from 'astro:assets';
import photo from '../assets/groupPhoto.webp';
const event = 'Fifth';
const day = 'July 2nd';
const time = '5:30p-7:00p';
const place = 'Atomic Object';
const address = '150 Fayetteville St. STE 400';
const city = 'Raleigh, NC';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Code Club RDU</title>
	</head>

	<body>
		<Header />
		<div class="">
			<h1 class="mb-3 text-center text-2xl">Welcome to <b>Code Club</b> RDU's homepage</h1>
			<div class="flex flex-col p-5">
				<p>
					We're a group of North Carolina based developers who want to hone their craft through
					hands-on practice and collaborative learning. Whether you're self-taught, boot camp
					trained or CS degreed, you have a place with us.
				</p>
				<p>Join us every first Thursday of the month to share ideas, connect, and practice</p>
				<div class="place-self-center pt-5">
					<Image
						src={photo}
						alt="Photo of group members"
						widths={[400, 800, 1200]}
						quality="mid"
						sizes="(max-width: 768px) 400px, (max-width: 1024px) 800px, 1200px"
					/>
				</div>
				<div>
					<p class="text-center">Next Event:</p>
					<div
						class="container mr-25 ml-25 flex w-1/3 flex-col place-self-center border-solid border-black pl-5"
					>
						<p class="leading-tight">
							{event} Event:<br />
							<br />
							{day}<br />
							{time}<br />
							<br />
							{place}<br />
							{address}<br />
							{city}
						</p>
						<div class="mb-4 flex flex-row justify-between pr-5">
							<button class="h-6 w-35 bg-black text-white"> MoreInfo </button>
							<button class="hover: rgb(70.7% 0.022 261.325) mr-1 h-6 w-35 bg-black text-white">
								RSVP on meetup
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</body>
</html>
